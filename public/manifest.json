{
  "manifest_version": 3,
  "name": "SnippetDeck Pro",
  "version": "1.0.0",
  "description": "Smart technical snippets for effortless demos.",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
